BETFAIR_USERNAME=your_username
BETFAIR_PASSWORD=your_password
BETFAIR_APP_KEY=your_app_key
# Paths to SSL certs downloaded from the Betfair developer portal
# (same certs as pl-predictor — copy them to tennis-predictor/certs/)
BETFAIR_CERT_PATH=certs/client-2048.crt
BETFAIR_KEY_PATH=certs/client-2048.key
